# Copy to `.env.local` (gitignored). Never commit real secrets.

# --- Supabase (see https://supabase.com/docs/guides/getting-started/quickstarts/nextjs ) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Optional alias if you still use the legacy anon key name:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: User management (create/delete auth users) and admin reads
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Legacy app password (no longer used — authentication is Supabase email/password)
# APP_PASSWORD=

TREEZ_CERT_ID=your-certificate-id-uuid
TREEZ_ORG_ID=your-organization-id-uuid

# Optional — only if you call dispensary-scoped discount APIs
# TREEZ_DISPENSARY=your_dispensary_subdomain

# Use a PEM file (recommended) or inline PEM with \n for line breaks:
TREEZ_PRIVATE_KEY_FILE=.treez/private.pem
# TREEZ_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional (default: https://api-prod.treez.io)
# TREEZ_API_BASE=https://api-prod.treez.io
